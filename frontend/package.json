{
  "name": "test-project",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build:css": "npx postcss src/index.css -o dist/output.css",
    "build:ts": "npx tsc src/index.ts --outDir dist --target ES6 --module none",
	"copy:html": "cp src/index.html dist/index.html",
	"copy:assets": "cp -r src/assets dist/assets",
    "build": "npm run build:css && npm run build:ts && npm run copy:html && npm run copy:assets"
  },
